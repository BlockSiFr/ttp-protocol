# TTP Trust Authority Configuration
# Copy to .env and fill in values.
# Generate keypair: npm run generate-keys

PORT=3000
AUTHORITY_URL=http://localhost:3000
AUTHORITY_KEY_ID=authority-key-2026-01

# Generate with: npm run generate-keys
AUTHORITY_PRIVATE_KEY=
AUTHORITY_PUBLIC_KEY=

# Admin API key — protect this
ADMIN_API_KEY=change-me-in-production

NODE_ENV=development
