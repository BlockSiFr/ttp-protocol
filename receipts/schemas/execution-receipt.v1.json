{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ttp.dev/receipts/schemas/execution-receipt.v1.json",
  "title": "ExecutionReceiptV1",
  "type": "object",
  "required": [
    "receiptId",
    "subject",
    "action",
    "resource",
    "decision",
    "trustScoreAtDecision",
    "authorityGrantRef",
    "attestationRef",
    "risk",
    "compliance",
    "cost",
    "repo",
    "branch",
    "pathsTouched",
    "workflowRunId",
    "commitSha",
    "invokingActor",
    "timestamp",
    "signature",
    "chainHash"
  ],
  "properties": {
    "receiptId": { "type": "string" },
    "subject": { "type": "string" },
    "action": { "type": "string" },
    "resource": { "type": "string" },
    "decision": { "type": "string", "enum": ["PERMIT", "STEP_UP", "ESCALATE", "DENY"] },
    "trustScoreAtDecision": { "type": "number", "minimum": 0, "maximum": 1 },
    "authorityGrantRef": { "type": "string" },
    "attestationRef": { "type": "string" },
    "risk": { "type": "object" },
    "compliance": { "type": "object" },
    "cost": { "type": "object" },
    "repo": { "type": "string" },
    "branch": { "type": "string" },
    "pathsTouched": { "type": "array", "items": { "type": "string" } },
    "workflowRunId": { "type": "string" },
    "commitSha": { "type": "string" },
    "invokingActor": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "signature": { "type": "string" },
    "chainHash": { "type": "string" }
  }
}
